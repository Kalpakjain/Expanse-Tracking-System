APP_NAME=Smart Expense Tracker API
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_ORIGINS=http://localhost:3000
DATABASE_URL=sqlite:///./expense_tracker.db
DATABASE_AUTO_CREATE_TABLES=true
REDIS_URL=redis://redis:6379/0
AUTH_SECRET_KEY=replace-with-a-long-random-secret-before-deploying
AUTH_TOKEN_TTL_MINUTES=10080
AUTH_REQUIRED=false
DEMO_USER_EMAIL=demo@fintrack.local
DEMO_USER_PASSWORD=demo12345
