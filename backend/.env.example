APP_NAME=Smart Expense Tracker API
APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
DATABASE_URL=postgresql://expense_user:expense_password@localhost:5432/expense_tracker
DATABASE_AUTO_CREATE_TABLES=false
REDIS_URL=redis://redis:6379/0
AUTH_SECRET_KEY=replace-with-a-long-random-secret-before-deploying
AUTH_TOKEN_TTL_MINUTES=10080
AUTH_REQUIRED=false
DEMO_USER_EMAIL=demo@fintrack.local
DEMO_USER_PASSWORD=demo12345
EMAIL_ENABLED=false
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=your-brevo-smtp-login@example.com
BREVO_SMTP_PASS=your-brevo-smtp-key
SENDER_EMAIL=your-verified-sender@example.com
SENDER_NAME=FinTrack AI
OTP_TTL_MINUTES=5
OTP_RATE_LIMIT_COUNT=3
OTP_RATE_LIMIT_WINDOW_MINUTES=10
OTP_MAX_ATTEMPTS=5
EXPOSE_DEV_OTP=false
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
RECEIPT_EXTRACTION_ENABLED=true
